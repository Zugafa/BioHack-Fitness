<header id="top">
    <h1><i class="fa-solid fa-microchip"></i>BioHack Fitness</h1>
    <nav>
        <!-- bonus meniu din 3 span -->
        <label id="hamburger" for="ch-menu">
            <div class="hamburger-icon">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </label>
        <input type="checkbox" id="ch-menu" />

        <ul class="meniu">

            <!-- MAINFRAME -->
            <li id="mainframe-item">
                <input type="checkbox" id="sub-mainframe" class="sub-toggle" />
                <label for="sub-mainframe">
                    <div class="text-icon">Mainframe</div>
                    <div class="imag-icon"><i class="fa-solid fa-house-signal"></i></div>
                </label>
                <ul>
                    <li><a href="/#welcome">Misiune</a></li>
                    <li><a href="/#system-alerts">Alerte</a></li>
                    <li><a href="/#echipa-biohack">Echipă</a></li>
                    <li><a href="/#sectiune-galerie-animata">Facilități</a></li>
                    <li><a href="/#system-status">Status & Insights</a></li>
                </ul>
            </li>

            <!-- PROTOCOLS (sub-optiuni generate din BD) -->
            <li>
                <input type="checkbox" id="sub-protocols" class="sub-toggle" />
                <label for="sub-protocols">
                    <div class="text-icon">Protocols</div>
                    <div class="imag-icon"><i class="fa-solid fa-dna"></i></div>
                </label>
                <ul>
                    <li><a href="/protocols">Toate Protocoalele</a></li>
                    <% if (locals.prod_categories && locals.prod_categories.length) { %>
                        <% for (let cat of locals.prod_categories) { %>
                            <li><a href="/protocols?departament=<%- encodeURIComponent(cat) %>"><%- cat %></a></li>
                        <% } %>
                    <% } else { %>
                        <li><a href="/protocols?departament=Biomechanical-\-Power">Biomechanical-Power</a></li>
                        <li><a href="/protocols?departament=Neural-Performance">Neural-Performance</a></li>
                        <li><a href="/protocols?departament=Recovery-Protocols">Recovery-Protocols</a></li>
                    <% } %>
                </ul>
            </li>

            <!-- THE LAB -->
            <li>
                <input type="checkbox" id="sub-lab" class="sub-toggle" />
                <label for="sub-lab">
                    <div class="text-icon">The Lab</div>
                    <div class="imag-icon"><i class="fa-solid fa-flask-vial"></i></div>
                </label>
                <ul>
                    <li><a href="/lab#forge">The Forge</a></li>
                    <li><a href="/lab#team-pt">Cyber-Coaches</a></li>
                    <li><a href="/lab#team-ba">Bio-Analysts</a></li>
                    <li><a href="/lab#team-hb">Heart-Boosters</a></li>
                </ul>
            </li>

            <!-- 4. ACCESS POINT -->
            <li>
                <input type="checkbox" id="sub-access" class="sub-toggle" />
                <label for="sub-access">
                    <div class="text-icon">Access Point</div>
                    <div class="imag-icon"><i class="fa-solid fa-location-crosshairs"></i></div>
                </label>
                <ul>
                    <li><a href="/contact#map">Localizare</a></li>
                    <li><a href="/contact#form">Formular Contact</a></li>
                    <li><a href="/contact#social">Rețele Sociale</a></li>
                </ul>
            </li>

            <!-- 5. JACK IN -->
            <li id="jack-in">
                <a href="/node">
                    <div class="text-icon">Jack In</div>
                    <div class="imag-icon"><i class="fa-solid fa-plug-circle-bolt"></i></div>
                </a>
            </li>

        </ul>
    </nav>
    <div class="ticker-container">
        <div class="ticker-text">
            <span>[USER: <%= locals.ip || 'UNKNOWN' %>] </span>
            <span>[STATUS: SYSTEM_ONLINE]</span>
            <span>"Efortul este singura monedă acceptată în sistem." — Arhitectul Șef</span>
            <span>"Durerea este doar un senzor defect. Ignoră avertismentul, atinge limita." — Echipa Cyber-Coaches</span>
            <span>"ADN-ul tău este doar cod moștenit. Noi livrăm patch-ul de performanță." — Echipa Bio-Analysts</span>
            <span>"Fiecare puls este o linie de cod. Fă-o să ruleze eficient." — Echipa Heart-Boosters</span>
        </div>
    </div>
</header>